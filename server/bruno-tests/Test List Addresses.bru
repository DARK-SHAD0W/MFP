meta {
  name: Test List Addresses
  type: http
  seq: 4
}

get {
  url: http://localhost:3000/api/addresses
  auth: bearer
}

headers {
  Authorization: Bearer {{token}}
}

auth:bearer {
  token: {{token}}
}

tests {
  test("Status should be 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response should have items array", function() {
    expect(res.body).to.have.property('items');
    expect(res.body.items).to.be.an('array');
  });

  test("Response headers should have content-type json", function() {
    expect(res.getHeader('content-type')).to.include('application/json');
  });
}
