meta {
  name: Test Register
  type: http
  seq: 1
}

post {
  url: http://localhost:3000/api/users
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
  "email": "testuser@example.com",
  "password": "TestPassword123"
  }
}

tests {
  test("Status should be 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response should have item", function() {
    expect(res.body).to.have.property('item');
  });

  test("Item should have id", function() {
    expect(res.body.item).to.have.property('id');
  });

  test("Item should have email", function() {
    expect(res.body.item).to.have.property('email');
  });

  test("Email should match request", function() {
    expect(res.body.item.email).to.equal("testuser@example.com");
  });
}
