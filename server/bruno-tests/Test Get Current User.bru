meta {
  name: Test Get Current User
  type: http
  seq: 3
}

get {
  url: http://localhost:3000/api/users/me
  auth: bearer
}

headers {
  Authorization: Bearer {{token}}
}

auth:bearer {
  token: {{token}}
}

tests {
  test("Status should be 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response should have item", function() {
    expect(res.body).to.have.property('item');
  });

  test("Item should have id", function() {
    expect(res.body.item).to.have.property('id');
  });

  test("Item should have email", function() {
    expect(res.body.item).to.have.property('email');
  });

  test("Item should have createdAt", function() {
    expect(res.body.item).to.have.property('createdAt');
  });

  test("Email should be string", function() {
    expect(res.body.item.email).to.be.a('string');
  });
}
