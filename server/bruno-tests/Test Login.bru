meta {
  name: Test Login
  type: http
  seq: 2
}

post {
  url: http://localhost:3000/api/users/tokens
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
  "email": "testuser@example.com",
  "password": "TestPassword123"
  }
}

tests {
  test("Status should be 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response should have token", function() {
    expect(res.body).to.have.property('token');
  });

  test("Token should be string", function() {
    expect(res.body.token).to.be.a('string');
  });

  test("Token should not be empty", function() {
    expect(res.body.token.length).to.be.greaterThan(0);
  });
}
